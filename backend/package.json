{
  "name": "gate-da-backend",
  "version": "1.0.0",
  "private": true,
  "description": "GATE DA Platform Backend — Express + MongoDB + Auth",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed:taxonomy": "ts-node scripts/seedTaxonomy.ts",
    "test:contest": "vitest run --config ../vitest.contest.config.ts ../tests/contest",
    "test:contest:admin": "vitest run --config ../vitest.contest.config.ts ../tests/contest/admin",
    "test:contest:user": "vitest run --config ../vitest.contest.config.ts ../tests/contest/user",
    "test:contest:scoring": "vitest run --config ../vitest.contest.config.ts ../tests/contest/scoring",
    "test:contest:standings": "vitest run --config ../vitest.contest.config.ts ../tests/contest/standings",
    "test:contest:security": "vitest run --config ../vitest.contest.config.ts ../tests/contest/security",
    "test:contest:performance": "vitest run --config ../vitest.contest.config.ts ../tests/contest/performance",
    "test:contest:e2e": "vitest run --config ../vitest.contest.config.ts ../tests/contest/e2e"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
